{
  "manifest_version": 3,
  "name": "Caffeinate — Keep Screen Awake",
  "version": "1.0.0",
  "description": "Keep your screen awake. Set a timer or run forever — one tap to start, one to stop.",
  "permissions": ["power", "storage", "alarms", "offscreen"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Caffeinate",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
